{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "command": "npm install && npm run build:server",
    "output": "dist"
  },
  "deploy": {
    "startCommand": "node dist/index.js",
    "env": {
      "NODE_ENV": "production",
      "PORT": "3001",
      "JWT_SECRET": "your-secure-jwt-secret-change-this"
    }
  }
}